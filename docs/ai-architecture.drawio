        <mxCell id="t2" value="Quyết định:&#10;APPLIED / APPLIED_PLUS5 /&#10;APPLIED_MINUS5 / SKIPPED" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
