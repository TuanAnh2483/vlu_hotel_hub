        <mxCell id="t4" value="Nightly cron 02:00 — trainForRoom()&#10;(cần ≥ 5 feedback / cửa sổ 60 ngày)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="720" y="210" width="310" height="60" as="geometry" />
        </mxCell>

        <mxCell id="tp1" value="Phase 1 — Feedback learning&#10;acceptance rate (time-decay λ=0.025)&#10;→ priceAggressiveness, partnerAdjustment" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="100" y="340" width="320" height="70" as="geometry" />
        </mxCell>
        <mxCell id="tp2" value="Phase 2 — Occupancy lịch sử&#10;(8 tuần) → weekday/weekend boost" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="430" y="340" width="300" height="70" as="geometry" />
        </mxCell>
        <mxCell id="tp3" value="Phase 3 — Logistic Regression&#10;8 features, weighted gradient descent&#10;→ w0…w7, lrReady=true" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="760" y="340" width="300" height="70" as="geometry" />
        </mxCell>

        <mxCell id="tm" value="PricingModel cập nhật&#10;(round++, lastTrainedAt)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="1">
          <mxGeometry x="430" y="480" width="300" height="60" as="geometry" />
        </mxCell>

        <mxCell id="tfeat" value="8 features của LR:&#10;[bias, priceUplift, isWeekend, isHoliday,&#10; sin(dow), cos(dow), leadTimeNorm, seasonalDeviation]&#10;optimizePrice quét 75%→150% giá gốc, chọn max(price × P(accept))" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="120" y="600" width="560" height="90" as="geometry" />
