        <mxCell id="t3" value="PriceFeedback lưu DB&#10;(POST /price-feedback)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;" vertex="1" parent="1">
          <mxGeometry x="790" y="85" width="240" height="60" as="geometry" />
